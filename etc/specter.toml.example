# Specter configuration.
#
# Top-level sections:
#   [log]     engine telemetry (subprocess output is per-watch — see
#             `log_output` below)
#   [[watch]] one entry per filesystem subscription

[log]
level       = "info"     # trace | debug | info | warn | error
destination = "stderr"   # stderr | file  (when "file", path is required)
# path      = "/var/log/specter.log"

# Replace this example with one [[watch]] block per subscription. The
# `name`, `path`, and `actions` fields are required; everything else is
# optional and shown below with its default.
[[watch]]
name    = "example"
path    = "/srv/data"                         # absolute; lenient — pending paths are OK
actions = [{ exec = ["echo", "${specter.path}"] }]

# enabled    = true                           # false ⇒ inert at runtime; toggle without deleting
# settle     = "200ms"                        # quiet window before stable verdict
# max_settle = "1h"                           # forced-fire deadline
# scope      = "subtree-root"                 # | "per-stable-file"
# events     = ["structure", "content"]       # default depends on scope
# pattern    = "**/*.{c,h,rs}"
# exclude    = ["target/**", "node_modules/**"]
# hidden     = false
# recursive  = true
# max_depth  = 8                              # ≥ 1; omit for unbounded
# log_output = false                          # forward child stdio to specter

# Placeholders inside an exec argv slot:
#   ${specter.path}     ${specter.relative}   ${specter.anchor}
#   ${specter.parent}   ${specter.watch}      ${specter.time}
#   ${specter.created}  ${specter.deleted}    ${specter.modified}
#   ${specter.renamed_from}  ${specter.renamed_to}  ${specter.excluded}
#   ${env.NAME}         ${env.NAME:-default}  ${env.NAME:-}
#
# See docs/placeholders.md for the full grammar and rendering rules.
